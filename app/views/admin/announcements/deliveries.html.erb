<%= render 'admin/layout' do %>
  <h1>Announcement Deliveries</h1>

  <p>
    <strong>To:</strong>
    <%= @announcement.profile_names %>
  </p>

  <p>
    <strong>Time:</strong>
    <%= @announcement.publish_time&.strftime('%Y-%m-%d %H:%M') %>
  </p>

  <p>
    <strong>Announcement:</strong><br>
    <%= simple_format @announcement.body %>
  </p>

  <p>
    <strong>送信状況:</strong>
    <%= @announcement.send_status %>
    /
    <strong>送信数:</strong>
    <%= @announcement.sent_count %>
    /
    <strong>失敗数:</strong>
    <%= @announcement.failed_count %>
  </p>

  <p>
    <%= link_to 'Back to Announcements', admin_announcements_path, class: 'tw-inline-block tw-rounded tw-bg-gray-500 tw-px-4 tw-py-2 tw-font-bold tw-text-white hover:tw-bg-gray-600' %>
  </p>

  <table class="tw-mb-4 tw-w-full tw-border tw-border-gray-200 talks_table">
    <thead class="tw-bg-gray-100">
      <tr>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">ID</th>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">Email</th>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">Profile</th>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">Status</th>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">Provider Message ID</th>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">Last Error</th>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">Updated At</th>
      </tr>
    </thead>
    <tbody class="tw-divide-y tw-divide-gray-200">
      <% @announcement_deliveries.each do |delivery| %>
        <tr class="odd:tw-bg-white even:tw-bg-gray-50">
          <td class="tw-px-4 tw-py-2"><%= delivery.id %></td>
          <td class="tw-px-4 tw-py-2"><%= delivery.email %></td>
          <td class="tw-px-4 tw-py-2"><%= delivery.profile.present? ? "#{delivery.profile.last_name} #{delivery.profile.first_name}" : '' %></td>
          <td class="tw-px-4 tw-py-2"><%= delivery.status %></td>
          <td class="tw-px-4 tw-py-2"><%= delivery.provider_message_id %></td>
          <td class="tw-px-4 tw-py-2"><%= delivery.last_error %></td>
          <td class="tw-px-4 tw-py-2"><%= delivery.updated_at&.strftime('%Y-%m-%d %H:%M:%S') %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
