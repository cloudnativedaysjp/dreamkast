<tr class="link-field odd:tw-bg-white even:tw-bg-gray-50" data-controller="remove-link-field" data-remove-link-field-target="linkField">
  <td class="tw-px-4 tw-py-2"><%= f.text_field :title %></td>
  <td class="tw-px-4 tw-py-2"><%= f.text_field :url %></td>
  <td class="tw-px-4 tw-py-2"><%= f.text_field :description %></td>
  <td class="tw-px-4 tw-py-2">
    <%= f.hidden_field :_destroy, data: { "remove-link-field-target": "hiddenInput" } %>
    <button type='button' class="tw-inline-block tw-rounded tw-bg-red-600 tw-px-2 tw-py-1 tw-text-sm tw-font-bold tw-text-white hover:tw-bg-red-700" data-action="click->remove-link-field#remove">Delete</button>
  </td>
</tr>
