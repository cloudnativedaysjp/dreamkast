<div id="preview_url"><%= @preview_url %></div>

<video
  id="my-player"
  class="video-js vjs-default-skin"
  data-setup='{"fluid": true}'
  controls
  preload="auto"
>
  <source src="<%= @preview_url %>" type="application/x-mpegURL" />
</video>

<%= form_with(url: admin_harvest_jobs_path, model: @harvest_job, method: :post, data: { action: "turbo:submit-end->modal#close" }) do |form| %>
  <section class="speaker-information tw-py-3">
    <%= form.hidden_field :media_package_channel_id, value: @media_package_channel.id %>
    <%= form.hidden_field :talk_id, value: @talk.id %>

    <div class="field">
      <%= form.label :start_time,'切り出し開始時刻' %>*<br/>
      <%= form.text_field :start_time, value: @initial_start_time, id: 'start-time-field', class: 'tw-block tw-w-full tw-rounded tw-border tw-border-gray-300 tw-px-3 tw-py-2 focus:tw-border-blue-500 focus:tw-ring-1 focus:tw-ring-blue-500' %>
    </div>

    <div class="field">
      <%= form.label :end_time, '切り出し終了時刻' %>*<br/>
      <%= form.text_field :end_time, value: @initial_end_time, id: 'end-time-field', class: 'tw-block tw-w-full tw-rounded tw-border tw-border-gray-300 tw-px-3 tw-py-2 focus:tw-border-blue-500 focus:tw-ring-1 focus:tw-ring-blue-500' %>
    </div>

    <div class="field">
      <button type="button" id="update-start-and-end" class="tw-inline-block tw-rounded tw-bg-gray-500 tw-px-4 tw-py-2 tw-font-bold tw-text-white hover:tw-bg-gray-600">Update</button>
    </div>

    <div class="actions tw-justify-center tw-py-3">
      <%= form.submit class: "tw-inline-block tw-rounded tw-bg-blue-600 tw-px-6 tw-py-3 tw-text-lg tw-font-bold tw-text-white hover:tw-bg-blue-700 tw-block tw-w-full" %>
    </div>
  </section>
<% end %>

<script>
  const player = videojs('my-player');
  function inputChange(){
    const s = document.getElementById('start-time-field').value;
    const e = document.getElementById('end-time-field').value
    const preview_url = `<%= @base_url %>?start=${s}&end=${e}`
    document.getElementById('preview_url').innerHTML = preview_url
    player.src(preview_url)
  }
  s = document.getElementById('update-start-and-end')
  s.addEventListener( "click", inputChange ) ;

  player.play();
</script>
