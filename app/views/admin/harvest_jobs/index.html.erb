<%= render 'admin/layout' do %>
  <h2 class="tw-mb-4 tw-text-2xl tw-font-semibold tw-text-gray-900">HarvestJobs</h2>

  <div class="admin-table-scroll">
    <table class="admin-table talks_table">
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Harvest Job ID</th>
          <th scope="col">Harvest Job Status</th>
          <th scope="col">StartTime</th>
          <th scope="col">EndTime</th>
          <th scope="col">Video URL</th>
        </tr>
      </thead>
      <tbody>
        <% @harvest_jobs.each do |harvest_job| %>
          <tr>
            <td><%= harvest_job.id %></td>
            <td><%= harvest_job.job_id %></td>
            <td><%= harvest_job.job&.status %></td>
            <td><%= harvest_job.start_time %></td>
            <td><%= harvest_job.end_time %></td>
            <td>
              <div class="tw-flex tw-items-start tw-gap-2" data-controller="copy">
                <span class="tw-break-all" data-copy-target="url"><%= harvest_job.video_url %></span>
                <% if harvest_job.video_url.present? %>
                  <button type="button"
                          class="tw-inline-flex tw-shrink-0 tw-cursor-pointer tw-items-center tw-justify-center tw-rounded-md tw-p-1 tw-text-gray-500 hover:tw-bg-gray-100 hover:tw-text-blue-600"
                          data-action="click->copy#copy"
                          data-copy-target="button"
                          title="URLをコピー"
                          aria-label="URLをコピー">
                    <%= image_tag 'icons/copy.svg', size: '16x16', alt: '' %>
                  </button>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
