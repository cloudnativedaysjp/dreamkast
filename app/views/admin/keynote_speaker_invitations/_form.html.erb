  <%= form_with(model: [:admin, keynote_speaker_invitation], url: admin_keynote_speaker_invitations_path(event: @conference.abbr), data: { action: "turbo:submit-end->modal#close" }) do |form| %>
    <% if keynote_speaker_invitation.errors.any? %>
      <div class="tw-mb-4 tw-rounded tw-border tw-border-red-300 tw-bg-red-50 tw-p-4 tw-text-red-800">
        <h6>エラーがあります:</h6>
        <ul class="tw-mb-0">
          <% keynote_speaker_invitation.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="tw-mb-4">
      <%= form.label :email, 'メールアドレス', class: 'tw-mb-2 tw-block tw-text-sm tw-font-medium tw-text-gray-700' %>
      <%= form.email_field :email, class: 'tw-block tw-w-full tw-rounded tw-border tw-border-gray-300 tw-px-3 tw-py-2 focus:tw-border-blue-500 focus:tw-ring-1 focus:tw-ring-blue-500', required: true %>
      <div class="tw-mt-1 tw-text-sm tw-text-gray-500">招待メールを送信するメールアドレスを入力してください。</div>
    </div>

    <div class="tw-mb-4">
      <%= form.label :name, '名前（オプション）', class: 'tw-mb-2 tw-block tw-text-sm tw-font-medium tw-text-gray-700' %>
      <%= form.text_field :name, class: 'tw-block tw-w-full tw-rounded tw-border tw-border-gray-300 tw-px-3 tw-py-2 focus:tw-border-blue-500 focus:tw-ring-1 focus:tw-ring-blue-500' %>
      <div class="tw-mt-1 tw-text-sm tw-text-gray-500">事前に名前がわかっている場合は入力してください。</div>
    </div>

    <div class="tw-mb-4 tw-rounded tw-border tw-border-blue-300 tw-bg-blue-50 tw-p-4 tw-text-blue-800">
      <h6>招待を送信すると以下が自動的に作成されます：</h6>
      <ul class="tw-mb-0">
        <li>暫定スピーカー情報（後で編集可能）</li>
        <li>暫定キーノートセッション（後で編集可能）</li>
        <li>プロポーザル（採択済みステータス）</li>
      </ul>
      <p class="tw-mb-0 tw-mt-2">スピーカーが承諾すると、speaker_dashboardから自身の情報を編集できるようになります。</p>
    </div>

    <div class="tw-flex tw-gap-2">
      <%= form.submit '招待メールを送信', class: 'tw-inline-block tw-rounded tw-bg-blue-600 tw-px-4 tw-py-2 tw-font-bold tw-text-white hover:tw-bg-blue-700' %>
      <button type="button" class="tw-inline-block tw-rounded tw-bg-gray-500 tw-px-4 tw-py-2 tw-font-bold tw-text-white hover:tw-bg-gray-600" data-bs-dismiss="modal">
        キャンセル
      </button>
    </div>
  <% end %>
