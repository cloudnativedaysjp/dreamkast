<%= turbo_frame_tag 'invitations-list' do %>
  <div class="tw-overflow-hidden tw-rounded-md tw-border tw-border-gray-200 tw-bg-white tw-shadow-sm">
    <div class="tw-border-b tw-border-gray-200 tw-bg-gray-50 tw-px-4 tw-py-2 tw-text-sm tw-font-semibold tw-text-gray-700">
      招待一覧
    </div>
    <% if keynote_speaker_invitations.any? %>
      <div class="admin-table-scroll tw-rounded-none tw-border-0 tw-shadow-none">
        <table class="admin-table">
          <thead>
            <tr>
              <th scope="col">メールアドレス</th>
              <th scope="col">名前</th>
              <th scope="col">スピーカー</th>
              <th scope="col">セッション</th>
              <th scope="col">招待日時</th>
              <th scope="col">有効期限</th>
              <th scope="col">ステータス</th>
              <th scope="col">操作</th>
            </tr>
          </thead>
          <tbody>
            <% keynote_speaker_invitations.each do |invitation| %>
              <tr>
                <td><%= invitation.email %></td>
                <td><%= invitation.name || '-' %></td>
                <td>
                  <% if invitation.speaker %>
                    <%= link_to invitation.speaker.name, edit_admin_speaker_path(event: @conference.abbr, id: invitation.speaker.id) %>
                  <% else %>
                    -
                  <% end %>
                </td>
                <td>
                  <% if invitation.talk %>
                    <%= link_to invitation.talk.title, edit_admin_talk_path(event: @conference.abbr, id: invitation.talk.id) %>
                  <% else %>
                    -
                  <% end %>
                </td>
                <td><%= l(invitation.invited_at, format: :short) if invitation.invited_at %></td>
                <td><%= l(invitation.expires_at, format: :short) if invitation.expires_at %></td>
                <td>
                  <% if invitation.accepted? %>
                    <span class="tw-inline-flex tw-items-center tw-rounded-full tw-bg-green-600 tw-px-2 tw-py-1 tw-text-xs tw-font-semibold tw-text-white">承諾済み</span>
                  <% elsif invitation.expired? %>
                    <span class="tw-inline-flex tw-items-center tw-rounded-full tw-bg-gray-500 tw-px-2 tw-py-1 tw-text-xs tw-font-semibold tw-text-white">期限切れ</span>
                  <% else %>
                    <span class="tw-inline-flex tw-items-center tw-rounded-full tw-bg-yellow-500 tw-px-2 tw-py-1 tw-text-xs tw-font-semibold tw-text-white">承諾待ち</span>
                  <% end %>
                </td>
                <td>
                  <% unless invitation.accepted? %>
                    <div class="tw-flex tw-flex-col tw-gap-1">
                      <%= button_to '再送信', resend_admin_keynote_speaker_invitation_path(event: @conference.abbr, id: invitation.id),
                                    method: :post, class: 'tw-inline-flex tw-items-center tw-rounded-md tw-border tw-border-blue-600 tw-px-3 tw-py-1.5 tw-text-xs tw-font-medium tw-text-blue-600 hover:tw-bg-blue-600 hover:tw-text-white',
                                    data: { turbo_method: :post, turbo_confirm: '招待メールを再送信しますか？' } %>
                      <%= button_to '削除', admin_keynote_speaker_invitation_path(event: @conference.abbr, id: invitation.id),
                                    method: :delete, class: 'tw-inline-flex tw-items-center tw-rounded-md tw-border tw-border-red-600 tw-px-3 tw-py-1.5 tw-text-xs tw-font-medium tw-text-red-600 hover:tw-bg-red-600 hover:tw-text-white',
                                    data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？関連するスピーカーとセッション情報も削除されます。' } %>
                    </div>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="tw-p-4 tw-text-center tw-text-gray-500">
        <p class="tw-mb-0">まだ招待がありません。</p>
      </div>
    <% end %>
  </div>
<% end %>
