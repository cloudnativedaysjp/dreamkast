<%= render 'admin/layout' do %>
  <% flash.each do |message_type, message| %>
    <div class="tw-mb-4 tw-rounded tw-border tw-border-blue-300 tw-bg-blue-50 tw-p-4 tw-text-blue-800" role="alert">
      <%= message %>
    </div>
  <% end %>

  <div class="tw-grid tw-grid-cols-12 tw-gap-4">
    <h2>Rooms</h2>
    <table class="tw-mb-4 tw-w-full tw-border tw-border-gray-200 talks_table">
      <thead class="tw-bg-gray-100">
      <tr>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">ID</th>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">Name</th>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">座席数</th>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">Track</th>
        <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left" scope="col">Description</th>
      </tr>
      </thead>
      <tbody class="tw-divide-y tw-divide-gray-200">
      <%= form_with(url: admin_rooms_path, id: "room_list", method: :put) do |f| %>
        <% @rooms.each do |room| %>
          <%= fields_for 'rooms[]', room do |fr| %>

            <tr class="odd:tw-bg-white even:tw-bg-gray-50">
              <td class="tw-px-4 tw-py-2"><%= room.id %></td>
              <td class="tw-px-4 tw-py-2"><%= room.name %></td>
              <td class="tw-px-4 tw-py-2">
                <% if room.track.present? %>
                  <%= fr.text_field :number_of_seats %>
                <% else %>
                  <%= fr.hidden_field :number_of_seats, value: 0 %>
                <% end %>
              </td>
              <td class="tw-px-4 tw-py-2">
                <%= room.track.present? ? room.track.name : '' %>
              </td>
              <td class="tw-px-4 tw-py-2">
                <%= fr.text_field :description %>
              </td>
            </tr>
          <% end %>
        <% end %>
      <% end %>
      </tbody>
    </table>
  </div>
<% end %>
<div id="transit_nav" class="tw-p-4">
  <%= submit_tag "保存", form: "room_list", class: "tw-inline-block tw-rounded tw-bg-red-600 tw-px-4 tw-py-2 tw-font-bold tw-text-white hover:tw-bg-red-700 transit_button" %>
  <br/><span class="tw-text-white"> ※トラックに紐付く各セッションの座席数も更新されます</span>
</div>
