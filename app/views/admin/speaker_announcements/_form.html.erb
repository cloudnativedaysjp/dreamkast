<%= form_with(url: speaker_announcement_url, model: @speaker_announcement) do |form| %>
  <section class="speaker-information tw-py-3">

    <div class="field">
      <%= form.label :publish_time, '公開日' %>*<br/>
      <%= form.datetime_select :publish_time, class: 'tw-block tw-w-full tw-rounded tw-border tw-border-gray-300 tw-px-3 tw-py-2 focus:tw-border-blue-500 focus:tw-ring-1 focus:tw-ring-blue-500' %>
    </div>

    <% unless @speakers.blank? || @speakers.nil? %>
        <div class="field">
          <%= form.label :speaker_id, '登壇者' %>*<br/>

          <!-- @speakers.length == 1 -->
          <% @speakers.each do |speaker| %>
            <%= form.hidden_field :speaker_ids, multiple: true, value: speaker.id %>
          <% end %>
          <%= form.text_field :speaker_names, value: @speakers.length == 1 ? @speakers[0].name : "全員", readonly: true %>
        </div>
    <% end %>
    <br/>
    <% if is_to_all_announcements? %>
      <div class="field">
        <% @speaker_announcement.receiver = :all_speaker if @speaker_announcement.person? %>
        <%= form.radio_button :receiver, :only_accepted %>
        <%= form.label :receiver, 'CFP採択者にのみ通知', value: @speaker_announcement.receiver %>
        <br/>
        <%= form.radio_button :receiver, :all_speaker %>
        <%= form.label :receiver, 'CFP採択に関わらず通知', value: @speaker_announcement.receiver %>
      </div>
    <% else %>
    <div class="field">
        <%= form.hidden_field :receiver, value: :person %>
      </div>
    <% end %>

    <div class="field">
      <%= form.label :body, 'アナウンス内容' %>*
      <%= form.text_area :body, class: "tw-block tw-w-full tw-rounded tw-border tw-border-gray-300 tw-px-3 tw-py-2 focus:tw-border-blue-500 focus:tw-ring-1 focus:tw-ring-blue-500", required: true %>
    </div>

    <div class="field">
      <%= form.label :publish, '公開・非公開' %>*<br/>
      <%= form.select :publish, {'非公開': false, '公開': true}, class: "tw-block tw-w-full tw-rounded tw-border tw-border-gray-300 tw-px-3 tw-py-2 focus:tw-border-blue-500 focus:tw-ring-1 focus:tw-ring-blue-500", required: true %>
    </div>

    <div class="actions tw-justify-center tw-py-3">
      <%= form.submit class: "tw-inline-block tw-rounded tw-bg-blue-600 tw-px-6 tw-py-3 tw-font-bold tw-text-white tw-text-lg tw-block tw-w-full hover:tw-bg-blue-700" %>
    </div>
  </section>
<% end %>
