<div class="tw-mx-auto tw-w-full tw-px-4">
  <h2>Sponsor Contact Invites</h2>

  <div class="tw-mb-4">
    <%= link_to "New Invite",
                new_sponsor_contact_invite_path(sponsor_id: params[:sponsor_id]),
                class: "tw-inline-block tw-rounded tw-bg-blue-600 tw-px-4 tw-py-2 tw-font-bold tw-text-white hover:tw-bg-blue-700",
                data: { turbo_frame: "sponsor_contact_invite_modal" } %>
  </div>

  <div class="tw-overflow-x-auto">
    <table class="tw-w-full tw-border tw-border-gray-200">
      <thead>
        <tr>
          <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left">Email</th>
          <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left">Sponsor</th>
          <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left">Status</th>
          <th class="tw-border-b tw-px-4 tw-py-2 tw-text-left">Sent At</th>
        </tr>
      </thead>
      <tbody>
        <% @invites.each do |invite| %>
          <tr>
            <td class="tw-px-4 tw-py-2"><%= invite.email %></td>
            <td class="tw-px-4 tw-py-2"><%= invite.sponsor.name %></td>
            <td class="tw-px-4 tw-py-2"><%= invite.accepted? ? 'Accepted' : 'Pending' %></td>
            <td class="tw-px-4 tw-py-2"><%= l invite.created_at, format: :long %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= turbo_frame_tag "sponsor_contact_invite_modal" %>
