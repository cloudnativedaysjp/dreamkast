<div class="tw-mx-auto tw-w-full tw-px-4">
  <div class="tw-mb-6 tw-flex tw-flex-wrap tw-items-center tw-justify-between tw-gap-3">
    <h2 class="tw-text-2xl tw-font-semibold tw-text-gray-900">Sponsor Contact Invites</h2>
    <%= link_to "New Invite",
                new_sponsor_contact_invite_path(sponsor_id: params[:sponsor_id]),
                class: "tw-inline-flex tw-items-center tw-rounded-md tw-bg-blue-600 tw-px-4 tw-py-2 tw-text-sm tw-font-semibold tw-text-white tw-shadow-sm hover:tw-bg-blue-700",
                data: { turbo_frame: "sponsor_contact_invite_modal" } %>
  </div>

  <div class="admin-table-scroll">
    <table class="admin-table">
      <thead>
        <tr>
          <th scope="col">Email</th>
          <th scope="col">Sponsor</th>
          <th scope="col">Status</th>
          <th scope="col">Sent At</th>
        </tr>
      </thead>
      <tbody>
        <% @invites.each do |invite| %>
          <tr>
            <td><%= invite.email %></td>
            <td><%= invite.sponsor.name %></td>
            <td><%= invite.accepted? ? 'Accepted' : 'Pending' %></td>
            <td><%= l invite.created_at, format: :long %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= turbo_frame_tag "sponsor_contact_invite_modal" %>
