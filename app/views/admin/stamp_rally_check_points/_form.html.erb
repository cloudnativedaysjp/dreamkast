<%= turbo_frame_tag stamp_rally_check_point.becomes(StampRallyCheckPoint) do %>
  <%= form_with(model: [:admin, stamp_rally_check_point.becomes(StampRallyCheckPoint)],
                url: @stamp_rally_check_point.new_record? ? admin_stamp_rally_check_points_path(event: params[:event]) : admin_stamp_rally_check_point_path(@stamp_rally_check_point, event: params[:event]),
                data: { action: "turbo:submit-end->modal#close" }) do |form| %>
    <% if stamp_rally_check_point.errors.any? %>
      <ul>
        <% stamp_rally_check_point.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>
    <div class="tw-grid tw-grid-cols-12 tw-gap-4 tw-border-t tw-py-2" data-controller="sponsor">
      <div class="tw-col-span-12 tw-mb-4">
        <%= form.label :name, class: "tw-mb-2 tw-block tw-text-sm tw-font-medium tw-text-gray-700" %>
        <%= form.text_field :name, class: "tw-block tw-w-full tw-rounded tw-border tw-border-gray-300 tw-px-3 tw-py-2 focus:tw-border-blue-500 focus:tw-ring-1 focus:tw-ring-blue-500" %>
      </div>
      <div class="tw-col-span-12 tw-mb-4">
        <%= form.label :description, class: "tw-mb-2 tw-block tw-text-sm tw-font-medium tw-text-gray-700" %>
        <%= form.text_area :description, class: "tw-block tw-w-full tw-rounded tw-border tw-border-gray-300 tw-px-3 tw-py-2 focus:tw-border-blue-500 focus:tw-ring-1 focus:tw-ring-blue-500" %>
      </div>
      <div class="tw-col-span-12 tw-mb-4">
        <%= form.label :type, class: "tw-mb-2 tw-block tw-text-sm tw-font-medium tw-text-gray-700" %>
        <%= form.select :type, options_for_select(type_options, selected: stamp_rally_check_point.type), {},
                        {
                          class: "tw-block tw-w-full tw-rounded tw-border tw-border-gray-300 tw-px-3 tw-py-2 focus:tw-border-blue-500 focus:tw-ring-1 focus:tw-ring-blue-500",
                          id: "stamp_rally_check_point_type",
                          data: {
                            target: "sponsor.type",
                            action: "change->sponsor#handleTypeChange"
                          }
                        }
        %>
      </div>
      <div class="tw-col-span-12 tw-mb-4" data-target="sponsor.sponsorField" >
        <%= form.label :sponsor_id, class: "tw-mb-2 tw-block tw-text-sm tw-font-medium tw-text-gray-700"  %>
        <%= form.collection_select :sponsor_id, sponsors, :id, :name, {include_blank: true},
                                   {
                                     class: "tw-block tw-w-full tw-rounded tw-border tw-border-gray-300 tw-px-3 tw-py-2 focus:tw-border-blue-500 focus:tw-ring-1 focus:tw-ring-blue-500",
                                     id: "stamp_rally_check_point_sponsor_id"
                                   }
        %>
      </div>

      <div class="tw-col-span-12 tw-mb-4">
        <div class="tw-flex tw-justify-end">
          <%= form.submit class: "tw-inline-block tw-rounded tw-bg-blue-600 tw-px-2 tw-py-1 tw-text-sm tw-font-bold tw-text-white hover:tw-bg-blue-700 tw-mr-2" %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
