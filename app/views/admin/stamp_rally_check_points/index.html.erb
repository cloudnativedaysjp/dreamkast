<% provide(:title, 'スタンプラリーチェックポイント一覧') %>
<%= render 'admin/layout' do %>
  <h2 class="tw-mb-6 tw-text-2xl tw-font-semibold tw-text-gray-900">スタンプラリー</h2>

  <section class="tw-mb-8">
    <h3 class="tw-mb-3 tw-text-lg tw-font-semibold tw-text-gray-900">設定</h3>
    <%= turbo_frame_tag @stamp_rally_configure do %>
      <div class="admin-form-card">
        <%= render 'admin/stamp_rally_configures/stamp_rally_configure', stamp_rally_configure: @stamp_rally_configure %>
      </div>
    <% end %>
  </section>

  <section>
    <h3 class="tw-mb-3 tw-text-lg tw-font-semibold tw-text-gray-900">チェックポイント</h3>

    <%= turbo_frame_tag 'stamp_rally_check_point_list' do %>
      <div class="tw-mb-3 tw-flex tw-justify-end">
        <%= link_to '登録',
                    new_admin_stamp_rally_check_point_path,
                    class: 'admin-btn-primary',
                    data: { turbo_frame: 'modal' } %>
      </div>

      <div class="tw-overflow-hidden tw-rounded-lg tw-border tw-border-gray-200 tw-bg-white tw-shadow-sm">
        <div class="tw-grid tw-grid-cols-12 tw-gap-4 tw-bg-gray-50 tw-px-6 tw-py-3 tw-text-sm tw-font-semibold tw-text-gray-600">
          <div class="tw-col-span-1"></div>
          <div class="tw-col-span-2">Type</div>
          <div class="tw-col-span-2">Name</div>
          <div class="tw-col-span-2">Sponsor Name</div>
          <div class="tw-col-span-2"></div>
          <div class="tw-col-span-1"></div>
          <div class="tw-col-span-2"></div>
        </div>

        <div id="stamp_rally_check_points" data-controller="drag-drop" class="tw-divide-y tw-divide-gray-200">
          <% @stamp_rally_check_points.each do |stamp_rally_check_point| %>
            <%= render 'admin/stamp_rally_check_points/stamp_rally_check_point', conference: @conference, stamp_rally_check_point: stamp_rally_check_point %>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>

  <%= turbo_frame_tag 'modal' %>
  <div id="flashes" class="tw-fixed tw-bottom-0 tw-right-0" style="margin: 0.75rem"></div>
<% end %>
