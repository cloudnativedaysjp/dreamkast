<%= form_with(model: [:admin, stamp_rally_configure],
              url: stamp_rally_configure.new_record? ? admin_stamp_rally_configures_path(event: params[:event]) : admin_stamp_rally_configure_path(stamp_rally_configure, event: params[:event])) do |form| %>
  <div class="admin-form-section">
    <div>
      <%= form.label :finish_threshold, class: 'admin-form-label' %>
      <%= form.text_field :finish_threshold, class: 'admin-input' %>
      <p class="admin-form-hint">
        チェックイン数が指定した数値以上になった場合、フィニッシュ可能。-1 もしくは未設定の場合は全てチェックインするとフィニッシュ可能。
      </p>
    </div>

    <div class="tw-flex tw-justify-end">
      <%= form.submit class: 'admin-btn-primary' %>
    </div>
  </div>
<% end %>
