<%= render 'layout' do %>
  <h2 class="tw-mb-4 tw-text-2xl tw-font-semibold tw-text-gray-900">Session stats</h2>

  <div class="tw-mb-6">
    <h3 class="tw-mb-2 tw-text-lg tw-font-semibold tw-text-gray-900">Export to CSV</h3>
    <%= button_to admin_export_statistics_path, method: :get, class: 'tw-inline-flex tw-items-center tw-rounded-md tw-border tw-border-gray-300 tw-bg-white tw-px-4 tw-py-2 tw-text-sm tw-font-medium tw-text-gray-700 tw-shadow-sm hover:tw-bg-gray-50' do %>
      <%= render 'admin/download_icon' %>
      <span>エクスポート</span>
    <% end %>
  </div>

  <h2 class="tw-mb-4 tw-text-2xl tw-font-semibold tw-text-gray-900">Talks</h2>
  <div class="admin-table-scroll tw-mb-4">
    <table class="admin-table talks_table">
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Title</th>
          <th scope="col">登録者数(現地)</th>
          <th scope="col">登録者数(オンライン)</th>
          <th scope="col">チェックイン数</th>
          <th scope="col">オンライン視聴数</th>
        </tr>
      </thead>
      <tbody>
        <% @talks.each do |talk| %>
          <tr>
            <td><%= talk.id %></td>
            <td><%= talk.title %></td>
            <td><%= @offline_counts_by_talk[talk.id] %></td>
            <td><%= @online_counts_by_talk[talk.id] %></td>
            <td><%= @check_in_counts_by_talk[talk.id] || 0 %></td>
            <td><%= @online_viewers_by_talk[talk.id] || 'N/A' %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
