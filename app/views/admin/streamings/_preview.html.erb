<div class="tw-grid tw-grid-cols-12 tw-gap-4 tw-mb-2">
  <div class="tw-col-span-10 tw-flex tw-items-center">
    <h2>配信確認</h2>
  </div>
</div>

<% @tracks.each do |track| %>
  <div class="tw-col-span-10 tw-flex tw-items-center">
    <h3>Track <%= track.name %></h3>

    <% if track.streaming.present? %>
        <video
          id="my-player"
          class="video-js video-js vjs-16-9 vjs-big-play-centered"
          data-setup='{"fluid": true, "liveui": true, "enableWorker": true, "lowLatencyMode": true, "backBufferLength": 1}'
          controls
          preload="auto"
        >
          <source src="<%= track.streaming&.playback_url %>" type="application/x-mpegURL" />
        </video>
    <% end %>
  </div>
<% end %>
</div>
