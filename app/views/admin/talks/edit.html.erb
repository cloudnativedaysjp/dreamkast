<%= render 'admin/layout' do %>
  <% flash.each do |_message_type, message| %>
    <div class="tw-mb-4 tw-rounded tw-border tw-border-blue-300 tw-bg-blue-50 tw-p-4 tw-text-blue-800" role="alert">
      <%= message %>
    </div>
  <% end %>

  <h2 class="tw-mb-4 tw-text-2xl tw-font-semibold tw-text-gray-900">セッション編集</h2>

  <div class="admin-form-card">
    <%= form_with(model: @talk, scope: :talk, url: admin_talk_path(event: params[:event], id: @talk.id), local: true, method: :patch) do |form| %>
      <% if @talk.errors.any? %>
        <div id="error_explanation" class="tw-mb-5 tw-rounded-md tw-border tw-border-red-300 tw-bg-red-50 tw-p-4 tw-text-sm tw-text-red-800">
          <h5 class="tw-mb-2 tw-font-semibold">入力内容にエラーがあります:</h5>
          <ul class="tw-list-disc tw-space-y-1 tw-pl-5">
            <% @talk.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="admin-form-section">
        <div>
          <%= form.label :title, class: 'admin-form-label' do %>
            講演タイトル <span class="admin-form-required">*</span>
          <% end %>
          <%= form.text_field :title, class: 'admin-input', required: true %>
        </div>

        <div>
          <%= form.label :abstract, '講演内容', class: 'admin-form-label' %>
          <%= form.text_area :abstract, rows: 6, class: 'admin-textarea' %>
        </div>

        <div>
          <%= form.label :talk_category_id, 'カテゴリー', class: 'admin-form-label' %>
          <%= form.collection_select :talk_category_id, @talk_categories, :id, :name, { prompt: '選択してください' }, { class: 'admin-select' } %>
        </div>

        <div>
          <%= form.label :talk_difficulty_id, '受講者レベル', class: 'admin-form-label' %>
          <%= form.collection_select :talk_difficulty_id, @talk_difficulties, :id, :name, { prompt: '選択してください' }, { class: 'admin-select' } %>
        </div>

        <div>
          <%= form.label :track_id, 'トラック', class: 'admin-form-label' %>
          <%= form.collection_select :track_id, @tracks, :id, :name, { prompt: '選択してください' }, { class: 'admin-select' } %>
        </div>

        <div>
          <%= form.label :conference_day_id, '開催日', class: 'admin-form-label' %>
          <%= form.collection_select :conference_day_id, @conference_days, :id, :date, { prompt: '選択してください' }, { class: 'admin-select' } %>
        </div>

        <div class="tw-grid tw-grid-cols-1 tw-gap-4 md:tw-grid-cols-2">
          <div>
            <%= form.label :start_time, '開始時間', class: 'admin-form-label' %>
            <%= form.time_field :start_time, class: 'admin-input' %>
          </div>
          <div>
            <%= form.label :end_time, '終了時間', class: 'admin-form-label' %>
            <%= form.time_field :end_time, class: 'admin-input' %>
          </div>
        </div>

        <div>
          <%= form.label :document_url, 'セッション資料公開URL', class: 'admin-form-label' %>
          <%= form.url_field :document_url, class: 'admin-input' %>
        </div>

        <div>
          <%= form.label :ogp_image_url, 'OGP画像URL', class: 'admin-form-label' %>
          <%= form.url_field :ogp_image_url, class: 'admin-input', placeholder: 'https://example.com/og-image.png' %>
          <p class="admin-form-hint">
            SNSでシェアされた際に表示される画像のURLを指定できます。未指定の場合は登壇者のアバター画像が使用されます。
          </p>
        </div>

        <label class="tw-flex tw-cursor-pointer tw-items-center tw-gap-2 tw-text-sm tw-text-gray-700">
          <%= form.check_box :show_on_timetable, class: 'admin-checkbox' %>
          <span>タイムテーブルに表示</span>
        </label>

        <label class="tw-flex tw-cursor-pointer tw-items-center tw-gap-2 tw-text-sm tw-text-gray-700">
          <%= form.check_box :video_published, class: 'admin-checkbox' %>
          <span>動画公開</span>
        </label>

        <div>
          <span class="admin-form-label">セッションタイプ</span>
          <div class="tw-space-y-2">
            <% @talk_types.each do |talk_type| %>
              <label class="tw-flex tw-cursor-pointer tw-items-center tw-gap-2 tw-text-sm tw-text-gray-700">
                <%= check_box_tag 'talk[talk_type_ids][]', talk_type.id, @talk.talk_types.include?(talk_type),
                                  id: "talk_talk_type_ids_#{talk_type.id}", class: 'admin-checkbox' %>
                <span><%= talk_type.display_name %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# Proposal Items %>
        <% @conference.proposal_item_configs.map(&:item_number).uniq.each do |item_number| %>
          <% first_item = @conference.proposal_item_configs.find_by(item_number: item_number) %>
          <div>
            <% if first_item.class.to_s == 'ProposalItemConfigCheckBox' %>
              <% existing_proposal_item = @talk.proposal_items.find_by(label: first_item.label) %>
              <% existing_items = existing_proposal_item&.params || [] %>
              <% existing_items = existing_items.is_a?(Array) ? existing_items : [existing_items].compact %>

              <span class="admin-form-label"><%= first_item.item_name %></span>
              <div class="tw-space-y-2">
                <% @conference.proposal_item_configs.where(item_number: item_number).each do |item| %>
                  <% checked = existing_items.include?(item.id.to_s) %>
                  <label class="tw-flex tw-cursor-pointer tw-items-center tw-gap-2 tw-text-sm tw-text-gray-700">
                    <%= check_box_tag "talk[#{first_item.label}][]", item.id, checked,
                                      id: "talk_#{first_item.label}_#{item.id}", class: 'admin-checkbox' %>
                    <span><%= item.params %></span>
                  </label>
                <% end %>
              </div>

            <% elsif first_item.class.to_s == 'ProposalItemConfigRadioButton' %>
              <% existing_proposal_item = @talk.proposal_items.find_by(label: first_item.label) %>
              <% existing_item = existing_proposal_item&.params %>

              <span class="admin-form-label"><%= first_item.item_name %></span>
              <% if first_item.description.present? %>
                <p class="admin-form-hint tw-mb-2"><%= first_item.description.html_safe %></p>
              <% end %>
              <div class="tw-space-y-2">
                <% @conference.proposal_item_configs.where(item_number: item_number).each do |item| %>
                  <% checked = existing_item.to_s == item.id.to_s %>
                  <label class="tw-flex tw-cursor-pointer tw-items-center tw-gap-2 tw-text-sm tw-text-gray-700">
                    <%= radio_button_tag "talk[#{first_item.label}]", item.id, checked,
                                         id: "talk_#{first_item.label}_#{item.id}", class: 'admin-radio' %>
                    <span><%= item.params %></span>
                  </label>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <div class="tw-mt-2 tw-flex tw-flex-wrap tw-gap-2">
          <%= form.submit '更新', class: 'admin-btn-primary' %>
          <%= link_to '戻る', admin_talks_path(event: params[:event]), class: 'admin-btn-secondary' %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
