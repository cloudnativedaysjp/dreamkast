<%= render 'admin/layout' do %>
  <h2 class="tw-mb-4 tw-text-2xl tw-font-semibold tw-text-gray-900">ビデオファイル提出状況</h2>

  <ul class="tw-mb-6 tw-text-sm tw-text-gray-700">
    <li>確認状況: <%= @talks.count{|talk| talk.video_registration&.confirmed? } %>/<%= @talks.size %></li>
  </ul>

  <div class="admin-table-card">
    <table class="admin-table talks_table">
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Name</th>
          <th scope="col">Title</th>
          <th scope="col">Status</th>
          <th scope="col">Statistics</th>
          <th scope="col">YouTube</th>
        </tr>
      </thead>
      <tbody>
        <% @talks.each do |talk| %>
          <tr>
            <td><%= talk.id %></td>
            <td><%= talk.speakers.map(&:name).join(", ") %></td>
            <td><%= talk.title %></td>
            <td><%= talk.video_registration&.status_message %></td>
            <td>
              <% if talk.video_registration.present? && talk.video_registration.statistics.present?  %>
                <% JSON.parse(talk.video_registration&.statistics).each  do |k, v| %>
                  <%= k %>: <%= v %><br>
                <% end %>
              <% end %>
            </td>
            <td>
              <% video = talk.video %>
              <% if video.present? %>
                <div class="tw-text-sm">YouTube状態: <%= video.youtube_upload_status %></div>
                <% if video.youtube_video_id.present? %>
                  <div class="tw-text-sm">
                    ID: <%= link_to video.youtube_video_id, "https://www.youtube.com/watch?v=#{video.youtube_video_id}", target: '_blank', rel: 'noopener' %>
                  </div>
                <% end %>
                <% if video.failed? && video.youtube_upload_error.present? %>
                  <div class="tw-text-sm tw-text-red-600" title="<%= video.youtube_upload_error %>">エラー</div>
                <% end %>
                <% if video.video_id.present? && !video.uploaded? && !video.converting? && !video.uploading? %>
                  <%= button_to(video.failed? ? '再アップロード' : 'YouTubeへアップロード',
                                upload_to_youtube_admin_video_path(video, event: @conference.abbr),
                                method: :post, data: { turbo: false }) %>
                <% end %>
              <% else %>
                <span class="tw-text-sm tw-text-gray-400">動画なし</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
