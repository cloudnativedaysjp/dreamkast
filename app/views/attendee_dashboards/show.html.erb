<div id="countdown" class='d-flex align-items-center justify-content-center hidden'>
    <div id="countdown-number"></div>
    <svg>
      <circle r="90" cx="100" cy="100" id="countdown-circle"></circle>
    </svg>
</div>

<div class="japanese-modern-theme">
<div class="container tracks attendee-dashboard">
  <div class="row">
    <section id="main-pane" class="col-12 col-md-8">

      <% if @profile.respond_to?(:early_bird?) && @profile.early_bird? %>
      <div class="dashboard-early-banner">
        <div class="dashboard-early-banner-title">先行申し込みありがとうございます</div>
        <p>こんなにも早く参加申し込みいただいた皆様に向けて、<span class="dotted-accent">特別なプレゼントをご用意しております</span>。お楽しみに！</p>
      </div>
      <% end %>

      <div class="dashboard-reminder">
        <div class="dashboard-reminder-title">遠隔地の方は、宿泊場所の確保を忘れずに</div>
        <p>関東圏など遠隔地から参加される方は、<span class="dotted-accent">値段が上がってしまう前に宿泊場所の確保をお願いします</span></p>
        <p>参考ブログ: <a href="https://kaigi.cloudnativedays.jp/blog/recommend-accomodations/" target="_blank" rel="noopener noreferrer">クラウドネイティブ会議 運営メンバーが選んだ宿泊施設</a></p>
      </div>

      <% if @conference.opened? %>
        <div class="dashboard-live-card">
          <div class="dashboard-live-title"><%= @conference.abbr.upcase %> 開催中！</div>
          <%= button_to '配信はこちらから', "/#{@conference.abbr}/ui/", {method: :get, class: "btn btn-lg" } %>
        </div>
      <% end %>
      <div class="dashboard-section dashboard-participation">
        <h3 class="dashboard-section-title">企画一覧</h3>
        <div class="row justify-content-md-center mb-5  align-items-center">
          <%= link_to "https://kaigi.cloudnativedays.jp/handson/", target: '_blank' do %>
              <div class='project'>
                <%= image_tag 'cnk/handson.png' %>
              </div>
          <% end %>
          <%= link_to "https://kaigi.cloudnativedays.jp/blog/gameday-3/", target: '_blank' do %>
              <div class='project'>
                <%= image_tag 'cnk/gameday.png' %>
              </div>
          <% end %>
        </div>
      </div>
      <% if @profile.instance_of?(Profile) %>
        <div class="dashboard-section dashboard-participation">
          <h3 class="dashboard-section-title">参加方法</h3>

          <div class="mb-4">
             <div class="dashboard-status-value mt-1"><%= @profile.participation_before_type_cast %></div>
          </div>
          <div class="dashboard-status-link mb-4">
            参加方法の変更は <%= link_to 'こちら', edit_profile_path(id: @profile.id) %> から
          </div>

          <% if @profile.attend_offline? %>
            <div class="alert alert-warning mb-4">
              <h6 class="alert-heading fw-semibold mb-3"><i class="bi bi-exclamation-triangle-fill me-2"></i>オフライン参加の方へ</h6>
              <ul class="mb-0 pl-3">
                <li>スマートフォンで受け付け用の二次元バーコードを表示する場合は <%= link_to 'こちら', profiles_view_qr_path, class: 'alert-link' %>。</li>
              </ul>
            </div>
          <% end %>

          <div class="dashboard-share" data-controller="share-registration">
              <label for="tweet_content" class="form-label mb-3">X(Twitter)でシェアしよう！</label>
              <div class="mb-3">
                <%
                  post = ""
                  if @conference.abbr == 'cnk'
                    post = "#cloudnativekaigi に参加申し込みしました！ https://kaigi.cloudnativedays.jp"
                  else
                    post = "##{@conference.abbr.upcase} に #{@profile.participation_before_type_cast} で参加申し込みしました！ https://event.cloudnativedays.jp/#{@conference.abbr}"
                  end
                %>
                <textarea data-share-registration-target="tweet_content" id="tweet_content" class="form-control" rows="3"><%= post %></textarea>
              </div>
              <div class="text-end">
                <button type="button" data-action="click->share-registration#windowOpen" id="twitter_share" class="btn btn-dark btn-sm px-4">
                  <i class="bi bi-twitter me-1"></i> X(Twitter)でシェア
                </button>
              </div>
          </div>
        </div>
      <% end %>

      <% unless @conference.abbr == 'cnk' %>
      <div class="dashboard-section">
        <h3 class="dashboard-section-title">配信スケジュール</h3>
        <div class="dashboard-schedule">
            <% @conference.conference_days.externals.each do |day| %>
            <div class="dashboard-schedule-day">
                <span class="dashboard-schedule-date"><%= day.date %></span>
                <span class="dashboard-schedule-time"><%= day.start_time.strftime("%H:%M") %> - <%= day.end_time.strftime("%H:%M") %></span>
            </div>
            <% end %>
            <div class="dashboard-schedule-note">
                <i class="bi bi-info-circle me-1"></i> 配信は本ページで行います。開始時刻になると自動的に切り替わります。
            </div>
        </div>
      </div>
      <% end %>

      <% if @speaker.present? && @speaker_announcements.present? %>
      <div class="mt-3">
        <%= render 'tracks/speaker_announcements', speaker_announcements: @speaker_announcements %>
      </div>
      <% end %>

      <% if @announcements.present? %>
      <div class="dashboard-section">
          <h3 class="dashboard-section-title">運営からのお知らせ</h3>
          <div class="dashboard-announcements">
            <% @announcements.order(publish_time: 'DESC').each do |announcement| %>
            <div class="announcement-item">
              <div class="announcement-date"><%= announcement.publish_time.strftime('%Y-%m-%d %H:%M') %></div>
              <div class="announcement-body"><%= simple_format announcement.body %></div>
            </div>
            <% end %>
          </div>
      </div>
      <% end %>

      <% if @conference.show_timetable_enabled? %>
      <div class="dashboard-section">
        <h3 class="dashboard-section-title">聴講予定セッション</h3>
        <div id="registered-talk-list">
          <% @profile.talks.each do |talk| %>
            <div class="dashboard-talk-card">
              <div class="d-flex justify-content-between align-items-start mb-2">
                 <div class="dashboard-talk-meta">
                    <%= talk.conference_day.date.strftime("%m/%d") %> <span class="mx-1">|</span> Track <%= talk.track.name %> <span class="mx-1">|</span> <%= talk.start_time.strftime("%H:%M") %>-<%= talk.end_time.strftime("%H:%M") %>
                 </div>
                 <div class="d-flex">
                  <% if talk.talk_difficulty.present? && talk.talk_difficulty_id != 4 && talk.talk_category_id != 18 %>
                    <span class="badge badge-light border mr-1 text-dark difficulty_<%= talk_difficulty(talk).id %>"><%= talk_difficulty(talk).name %></span>
                  <% end %>
                  <% if talk.talk_category_id.present? %>
                    <span class="badge badge-light border text-dark category_<%= talk_category(talk).id %>"><%= talk_category(talk).name %></span>
                  <% end %>
                 </div>
              </div>
              <div class="dashboard-talk-title"><%= link_to talk.title, talk_path(id: talk.id), class: "text-dark text-decoration-none" %></div>
            </div>
          <% end %>
          <div class="py-4 text-center">
            <div class="mb-3">
              <%= button_to '聴講予定セッションを変更する', timetables_path, {method: :get, class: "btn btn-primary btn-lg px-5 shadow-none" } %>
            </div>
            <div>
              <%= link_to profiles_calendar_path(format: :ics, code: @profile.calendar_unique_code), class: "btn btn-outline-dark btn-sm rounded-0" do %>
                 <i class="bi bi-calendar-check me-1"></i> カレンダーに登録
              <% end %>
            </div>
          </div>
        </div>
      </div>
      <% end %>

      <div class="dashboard-section dashboard-access mb-5">
        <h3 class="dashboard-section-title">現地会場 アクセス</h3>
        <div class="card overflow-hidden">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5410.401695467206!2d136.90701557723335!3d35.16835227275744!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x60037166d7205711%3A0x22bd3ac7bbcc0305!2z5Lit5pel44Ob44O844OrIO-8hiDjgqvjg7Pjg5XjgqHjg6zjg7Pjgrk!5e1!3m2!1sja!2sjp!4v1766231356712!5m2!1sja!2sjp" width="100%" height="400" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          <div class="card-body">
             <p class="card-text mb-0">
               <strong>〒460-0008</strong><br/>
               愛知県名古屋市中区栄４丁目１−１ 6F 中日ビル
             </p>
          </div>
        </div>
      </div>
    </section>
    <section id="sub-pane" class="col-12 col-md-4">
      <div class="dashboard-section">
        <h3 class="dashboard-section-title">リンク</h3>
        <div class="dashboard-links">
              <!-- TODO: CNDW2024参加証できたら有効化
              <%= link_to profiles_view_qr_path do %><i class="bi bi-qr-code"></i>参加用二次元バーコードを表示する<% end %>
              -->
              <%= link_to edit_profile_path(id: @profile.id, anchor: "participation") do %><i class="bi bi-pencil-square"></i>参加方法変更<% end %>
              <% if @profile.public_profile.present? %>
                <%= link_to edit_public_profile_path(id: @profile.public_profile&.id) do %><i class="bi bi-person-lines-fill"></i>公開プロフィールを変更する<% end %>
              <% else %>
                <%= link_to new_public_profile_path do %><i class="bi bi-person-plus-fill"></i>公開プロフィールを登録する<% end %>
              <% end %>
              <% if @conference.opened? %>
                <%= link_to stamp_rally_check_ins_path do %><i class="bi bi-check-circle-fill"></i>スタンプラリー<% end %>
              <% end %>
              <% if @conference.abbr == 'cnk' %>
                <%= link_to "https://kaigi.cloudnativedays.jp/blog", target: :_blank, rel: "noopener noreferrer" do %><i class="bi bi-journal-text"></i>Blog記事一覧<% end %>
              <% else %>
                <%= link_to "https://cloudnativedays.jp/posts/", target: :_blank, rel: "noopener noreferrer" do %><i class="bi bi-journal-text"></i>Blog記事一覧<% end %>
              <% end %>
        </div>
      </div>
      <% if @speaker.present? %>
      <div class="dashboard-section">
        <h3 class="dashboard-section-title">登壇者メニュー</h3>
        <div class="dashboard-links">
              <%= link_to speaker_dashboard_path do %><i class="bi bi-mic-fill"></i>登壇者ダッシュボード<% end %>
        </div>
      </div>
      <% end %>
    </section>
  </div>
  <% if @conference.show_sponsors %>
  <section class="page-section" id="sponsors">
    <%= render 'event/partial/sponsors', conference: @conference %>
  </section>
  <% end %>

</div>
</div>

<%= javascript_include_tag 'tracks/waiting_channel.js' %>
