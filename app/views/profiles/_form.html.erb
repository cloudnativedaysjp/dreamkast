<%= form_with(url: profile_url, model: @profile, class: "needs-validation cfp-form") do |form| %>
  <% if @profile.errors.any? %>
    <div id="error_explanation" class="alert alert-danger" role="alert">
      <h5 class="font-weight-bold">入力内容にエラーがあります:</h5>
      <ul>
        <% @profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="cfp-field-group mb-5">
    <h5 class="cfp-field-group-title mb-3 pb-2 border-bottom">基本情報</h5>

    <div class="row g-3 mb-3">
      <div class="col-12 col-md-6">
        <%= form.label :last_name, "姓", class: "form-label form-required fw-semibold" %>
        <%= form.text_field :last_name, required: true, class: "form-control", placeholder: "雲" %>
      </div>

      <div class="col-12 col-md-6">
        <%= form.label :first_name, "名", class: "form-label form-required fw-semibold" %>
        <%= form.text_field :first_name, required: true, class: "form-control", placeholder: "太郎" %>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-12 col-md-6">
        <%= form.label :last_name_kana, "姓(カナ)", class: "form-label form-required fw-semibold" %>
        <%= form.text_field :last_name_kana, required: true, class: "form-control", placeholder: "クラウド" %>
      </div>

      <div class="col-12 col-md-6">
        <%= form.label :first_name_kana, "名(カナ)", class: "form-label form-required fw-semibold" %>
        <%= form.text_field :first_name_kana, required: true, class: "form-control", placeholder: "タロウ" %>
      </div>
    </div>
  </div>

  <div class="cfp-field-group mb-5">
    <h5 class="cfp-field-group-title mb-3 pb-2 border-bottom">所属情報</h5>

    <div class="mb-3">
      <%= form.label :address_level1, "勤務先名/学校名（前株・後株などはセレクトボックスから選択ください）", class: "form-label form-required fw-semibold" %>
      <div class="row g-2">
        <div class="col-12 col-md-3">
          <%= form.collection_select :company_name_prefix_id, ::FormModels::CompanyNamePrefix.all, :id, :name, {prompt: "法人格を選択"}, {class: "form-control"} %>
        </div>

        <div class="col-12 col-md-6">
          <%= form.text_field :company_name, required: true, class: "form-control", placeholder: "クラウドネイティブデイズ" %>
        </div>

        <div class="col-12 col-md-3">
          <%= form.collection_select :company_name_suffix_id, ::FormModels::CompanyNameSuffix.all, :id, :name, {prompt: "法人格を選択"}, {class: "form-control"} %>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-12">
        <%= form.label :company_email, "勤務先メールアドレス", class: "form-label form-required fw-semibold" %>
        <%= form.email_field :company_email, required: true, class: "form-control", placeholder: "mail@example.com" %>
      </div>
    </div>

    <!-- 郵便番号と住所のセクションをStimulus Controllerでラップ -->
    <div data-controller="postal-code">
      <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
          <%= form.label :company_postal_code, "勤務先住所: 郵便番号", class: "form-label form-required fw-semibold" %>
          <%= form.text_field :company_postal_code,
              required: true,
              class: "form-control",
              minlength: "7",
              maxlength: "8",
              pattern: "(\\d{7}|\\d{3}-\\d{4})",
              placeholder: "1000001",
              autocomplete: "postal-code",
              data: {
                postal_code_target: "postalCode",
                action: "input->postal-code#search"
              } %>

          <!-- ローディング表示 -->
          <div class="d-none mt-2" data-postal-code-target="loading">
            <small class="text-muted">
              <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
              住所を検索中...
            </small>
          </div>

          <!-- エラー表示 -->
          <div class="d-none mt-2 text-danger" data-postal-code-target="error" role="alert"></div>
        </div>

        <div class="col-12 col-md-4">
          <%= form.label :company_address_level1, "都道府県", class: "form-label form-required fw-semibold" %>
          <%= form.collection_select :company_address_level1,
              CompanyAddressLevel1.all,
              :name,
              :name,
              {prompt: ""},
              {
                required: true,
                class: "form-control",
                autocomplete: "address-level1",
                data: { postal_code_target: "prefecture" }
              } %>
        </div>

        <div class="col-12 col-md-4">
          <%= form.label :company_address_level2, "市区町村", class: "form-label form-required fw-semibold" %>
          <%= form.text_field :company_address_level2,
              required: true,
              class: "form-control",
              placeholder: "港区",
              autocomplete: "address-level2",
              data: { postal_code_target: "city" } %>
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-12 col-md-6">
          <%= form.label :company_address_line1, "町名・番地", class: "form-label form-required fw-semibold"  %>
          <%= form.text_field :company_address_line1,
              required: true,
              class: "form-control",
              placeholder: "赤坂1−2−3",
              autocomplete: "address-line1",
              data: { postal_code_target: "addressLine1" } %>
        </div>
        <div class="col-12 col-md-6">
          <%= form.label :company_address_line2, "建物名など", class: "form-label fw-semibold" %>
          <%= form.text_field :company_address_line2,
              required: false,
              class: "form-control",
              autocomplete: "address-line2" %>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-12 col-md-6">
        <%= form.label :company_tel, "勤務先電話番号", class: "form-label form-required fw-semibold" %>
        <%= form.text_field :company_tel, required: true, class: "form-control", placeholder: "0300000000", pattern: "[\\d+-]*" %>
      </div>
      <div class="col-12 col-md-6">
        <%= form.label :company_fax, "勤務先FAX番号", class: "form-label fw-semibold" %>
        <%= form.text_field :company_fax, required: false, class: "form-control", placeholder: "0300000000", pattern: "[\\d+-]*" %>
      </div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-12">
        <%= form.label :department, "勤務先部署･所属 / 学部･学科･学年", class: "form-label form-required fw-semibold" %>
        <%= form.text_field :department, required: true, class: "form-control", placeholder: "クラウド開発部門" %>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-12">
        <%= form.label :position, "勤務先役職", class: "form-label form-required fw-semibold" %>
        <%= form.text_field :position, required: true, class: "form-control", placeholder: "一般 / 管理職 / CTO など" %>
      </div>
    </div>
  </div>

  <div class="cfp-field-group mb-5">
    <h5 class="cfp-field-group-title mb-3 pb-2 border-bottom">属性アンケート</h5>

    <div class="row g-3 mb-3">
      <div class="col-12 col-md-6">
        <%= form.label :number_of_employee_id, "従業員数", class: "form-label form-required fw-semibold" %>
        <%= form.collection_select :number_of_employee_id, ::FormModels::NumberOfEmployee.all, :id, :name, {prompt: ""}, {required: true, class: "form-control", autocomplete: "number-of-employee-id"} %>
      </div>
      <div class="col-12 col-md-6">
        <%= form.label :occupation_id, "職種", class: "form-label fw-semibold" %>
        <%= form.collection_select :occupation_id, ::FormModels::Occupation.all, :id, :name, {prompt: "", disabled: ::FormModels::Occupation.all.map{|i| i.id if i.disabled}.compact}, {required: true, class: "form-control", autocomplete: "occupation_id"} %>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-12 col-md-6">
         <%= form.label :industry_id, "業種", class: "form-label fw-semibold" %>
         <%= form.grouped_collection_select(
           :industry_id,
           ::FormModels::Industry.all,
           :child,
           :name,
           :id, :name,
           {prompt: "選択してください"},
           {class: "form-control", autocomplete: "industry_id"}) %>
      </div>
      <div class="col-12 col-md-6">
        <%= form.label :annual_sales_id, "年商規模", class: "form-label fw-semibold" %>
        <%= form.collection_select :annual_sales_id, ::FormModels::AnnualSales.all, :id, :name, {prompt: ""}, {class: "form-control", autocomplete: "annual-sales-id"} %>
      </div>
    </div>
  </div>

  <div class="cfp-field-group mb-5" id="participation">
    <h5 class="cfp-field-group-title mb-3 pb-2 border-bottom">参加方法</h5>
    <div class="px-3">
        <div class="cfp-radio-card border p-3">
            <%= form.radio_button :participation, :online, { class: "form-check-input", id: "participation_online", required: true } %>
            <%= form.label :online, "リモート参加", { for: "participation_online", class: "form-check-label reached_capacity"} %>
            </br>
            <%= form.radio_button :participation, :offline, { class: "form-check-input", id: "participation_offline" , disabled: @conference.reach_capacity?, required: true, checked: @profile.participation.blank? || @profile.participation == 'offline' } %>
            <% if @conference.reach_capacity? %>
              <%= form.label :offline, "現地参加", { for: "participation_offline" , class: "form-check-label reached_capacity"} %>
              <span class="text-danger small d-block mt-1">現地参加は定員に達したためお申込みいただけません</span>
            <% else %>
              <%= form.label :offline, "現地参加", { for: "participation_offline", class: "form-check-label fw-semibold" } %>
            <% end %>
        </div>
    </div>
  </div>

  <% FormItem.where(conference_id: @conference.id).each do |form_item| %>
    <div class="cfp-field-group mb-4">
      <%= label_tag "form_item[#{form_item.attr}]", form_item.name, class: "form-label fw-semibold" %>
      <%
        # 既存の回答があれば取得
        form_value = @profile.form_values.find_by(form_item_id: form_item.id)
        value = form_value ? form_value.value : nil
      %>
      <%= text_field_tag "form_item[#{form_item.attr}]", value, required: false, class: "form-control", placeholder: "" %>
    </div>
  <% end %>

  <% if action_name == "new" %>
  <div class="card mb-4">
    <div class="card-body">
      <div class="prose">
          <%= markdown @conference.privacy_policy %>
      </div>

      <div class="cfp-checkbox-card border p-3 mt-3">
        <%= form.check_box :agreement, {required: true, class: "form-check-input"}, true, false %>
        <label class="form-check-label form-required fw-semibold" for="agreement">個人情報の取り扱いについて同意する <span class="small fw-normal d-block text-muted">ご同意いただけない場合は本セミナーを受講いただくことは出来ません。</span></label>
      </div>
    </div>
  </div>
  <% end %>

  <div class="cfp-submit text-center py-4">
    <%= form.submit submit_button_label, class: "btn btn-primary btn-lg shadow-sm px-5" %>
  </div>
<% end %>
