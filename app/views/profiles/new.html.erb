<div class="japanese-modern-theme">
<div class="container">
  <div class="row justify-content-lg-center">
    <div class="col-12 col-lg-8 speaker-dashboard-form cfp-form py-4 my-3 px-md-5">
      <% flash.each do |message_type, message| %>
        <div class="alert alert-<%= alert_type(message_type) %> alert-dismissible fade show" role="alert">
          <%= message %>
        </div>
      <% end %>
      <h2 class="text-center cfp-dashboard-title mb-2">参加登録フォーム</h2>
      <p class="text-center text-muted mb-5"><%= @conference.name %></p>
      <% if logged_in? %>
        <%= render 'form', profile: @profile, submit_button_label: "個人情報保護方針に同意して参加登録" %>
      <% else %>
        <div class="col-12 align-self-baseline my-4 justify-content-center text-center">
          <%= button_to 'ログイン / サインアップ', '/auth/auth0', {method: :post, class: "btn btn-primary btn-lg mb-4" } %>
          <% if @conference.abbr == 'cnk' %>
            <%= label_tag 'entry', '参加登録するにはクラウドネイティブ会議へのサインアップが必要です', class: "text-muted" %>
          <% else %>
            <%= label_tag 'entry', '参加登録するにはCloudNative Daysへのサインアップが必要です', class: "text-muted" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
</div>
