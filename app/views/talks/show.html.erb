<% content_for(:ogp) do%>
  <meta property="og:url" content="<%= request.original_url %>" />
  <meta property="og:type" content="article" />
  <meta property="og:title" content="<%= full_title(@talk.title) %>" />
  <meta property="og:description" content="<%= @talk.abstract[0, 100] %>" />
  <meta property="og:image" content="<%= image_url @talk.ogp_image %>" />
<% end %>
<% provide(:title, @talk.title) %>

<div class="japanese-modern-theme proposal-show"
  <% if current_user && (@conference.opened? || @conference.closed?) %>
    data-controller="talk-logger"
    data-talk-logger-talk-id-value="<%= @talk.id %>"
    data-talk-logger-talk-name-value="<%= @talk.title %>"
    data-talk-logger-profile-id-value="<%= @profile.id %>"
    data-talk-logger-weaver-url-value="<%= vote_api_url %>"
  <% end %>
>
  <div class="container">
    <div class="proposal-content-wrap">
      <div class="proposal-card">
        <div class="proposal-card-body">

          <% if @talk.start_time.present? && @talk.end_time.present? && @talk.conference_day.present? %>
            <div class="proposal-status proposal-status-accepted">
              Track <%= @talk.track.name %> &mdash;
              <%= @talk.conference_day.date.strftime("%Y/%m/%d") %>
              <%= @talk.start_time.strftime("%H:%M") %>-<%= @talk.end_time.strftime("%H:%M") %>
            </div>
          <% elsif @talk.proposal.present? && !@talk.sponsor_session? %>
            <%= render 'proposals/partial_show/proposal_result', talk: @talk %>
          <% end %>

          <h1 class="proposal-title"><%= @talk.title %></h1>

          <div class="proposal-share mb-3">
            <%= render 'talks/partial_show/twitter_share_button', hash_tag: @conference.twitter_hashtag %>
            <%= render 'talks/partial_show/facebook_share_button', url: request.original_url %>
          </div>

          <div class="proposal-badges mb-4">
            <% if @talk.talk_difficulty.present? && @talk.talk_difficulty_id != 4 && @talk.talk_category_id != 18 %>
              <span class="proposal-badge proposal-badge-difficulty"><%= @talk.talk_difficulty.name %></span>
            <% end %>
            <% if @talk.talk_category.present? %>
              <span class="proposal-badge proposal-badge-category"><%= @talk.talk_category.name %></span>
            <% end %>
            <% if @talk.sponsor_session? %>
              <span class="proposal-badge proposal-badge-conference">スポンサーセッション</span>
            <% end %>
            <% if @talk.talk_category&.name != 'Keynote' && @talk.keynote? %>
              <span class="proposal-badge proposal-badge-conference">Keynote</span>
            <% end %>
            <% if (@conference.closed? || @conference.archived?) %>
              <% if video_archived?(@talk) %>
                <span class="proposal-badge proposal-badge-difficulty">アーカイブ視聴可</span>
              <% else %>
                <span class="proposal-badge proposal-badge-conference">アーカイブ視聴不可</span>
              <% end %>
            <% end %>
          </div>

          <% if display_video?(@talk) %>
            <%= render 'talks/partial_show/talk_video_block_videojs', talk: @talk %>
          <% end %>

          <div class="proposal-abstract">
            <%= simple_format @talk.abstract %>
          </div>

          <% if @talk.speakers.any? %>
            <div class="proposal-speakers">
              <h2 class="proposal-section-heading">Speaker</h2>
              <% @talk.speakers.each do |speaker| %>
                <div class="proposal-speaker-card">
                  <div class="proposal-speaker-avatar">
                    <%= image_tag speaker.avatar_or_dummy_url(:medium), class: 'rounded-circle', size: '100x100' %>
                  </div>
                  <div class="proposal-speaker-info">
                    <h3 class="proposal-speaker-name"><%= speaker.name %></h3>
                    <% if speaker.company.present? && speaker.company != "" %>
                      <p class="proposal-speaker-company"><%= speaker.company %></p>
                    <% end %>
                    <% if speaker.job_title.present? && speaker.job_title != "" %>
                      <p class="proposal-speaker-title"><%= speaker.job_title %></p>
                    <% end %>
                    <div class="proposal-speaker-social">
                      <% if speaker.twitter_id.present? %>
                        <a href="https://twitter.com/<%= speaker.twitter_id %>" target="_blank" rel="noopener noreferrer" class="proposal-social-link" title="Twitter">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        </a>
                      <% end %>
                      <% if speaker.github_id.present? %>
                        <a href="https://github.com/<%= speaker.github_id %>" target="_blank" rel="noopener noreferrer" class="proposal-social-link" title="GitHub">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                        </a>
                      <% end %>
                    </div>
                    <% if speaker.profile.present? && speaker.profile != "" %>
                      <div class="proposal-speaker-bio">
                        <%= simple_format(speaker.profile) %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if display_document?(@talk) %>
            <div class="mt-4 pt-3" style="border-top: 1px solid rgba(26,26,26,0.08)">
              <h2 class="proposal-section-heading">資料</h2>
              <p><a href="<%= @talk.document_url %>" target="_blank" style="color: #B93A32;">発表資料を見る &rarr;</a></p>
            </div>
          <% end %>

          <% if (@conference.registered? || @conference.opened?) && @conference.attendee_entry_enabled? && !(logged_in? && @profile.present?) %>
            <div class="text-center mt-5 mb-3">
              <%= link_to "このイベントに参加申し込み（参加無料）", registration_path, method: :get, class: "btn btn-primary btn-lg px-5" %>
            </div>
          <% end %>

          <% if @conference.present? && @conference.show_timetable_enabled? %>
            <div class="text-center mt-4 mb-3">
              <%= button_to 'タイムテーブルに戻る', timetables_path, method: :get, class: "btn btn-outline-secondary px-4" %>
            </div>
          <% end %>
        </div>
      </div>

      <% if @conference.attendee_entry_enabled? %>
        <div class="proposal-related mt-5">
          <h2 class="proposal-section-heading">他のセッションもチェック！</h2>
          <div class="proposal-related-grid">
            <% @conference.talks.accepted.where(show_on_timetable: true).where.not(id: @talk.id).shuffle[0..2].each do |talk| %>
              <%= link_to url_for(controller: "talks", action: "show", id: talk.id), class: "proposal-related-card" do %>
                <% if talk.speakers.any? %>
                  <div class="proposal-related-avatar">
                    <%= image_tag talk.speakers[0].avatar_or_dummy_url(:small), size: '48x48', class: 'rounded-circle' %>
                  </div>
                <% end %>
                <h3 class="proposal-related-title"><%= talk.title %></h3>
                <% if talk.abstract.present? %>
                  <p class="proposal-related-abstract"><%= truncate(talk.abstract, length: 80) %></p>
                <% end %>
                <% if talk.speakers.any? %>
                  <p class="proposal-related-speaker"><%= talk.speakers.map(&:name).join(', ') %></p>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%= javascript_include_tag 'vote_cfp.js' %>
